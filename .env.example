# ──────────────────────────────────────────────────────────────────────────────
# AllTeachers 환경 변수 템플릿
# 사용법: 이 파일을 .env 로 복사 후 값 채우기  →  cp .env.example .env
# .env 는 .gitignore 에 포함되어 커밋되지 않음
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=allteachers_db
DB_USERNAME=all_admin
DB_PASSWORD=

# ── Redis / Valkey ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=          # 비밀번호 없으면 빈 값

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=              # 256bit 이상 랜덤 문자열 (예: openssl rand -base64 64)

# ── OAuth2 ─────────────────────────────────────────────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Spring Mail ────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=           # 발신 이메일 (예: educompany@gmail.com)
MAIL_PASSWORD=           # Gmail 앱 비밀번호

# ── AWS S3 ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=            # 운영 배포 시 백엔드 주소 (예: https://api.allteachers.co.kr)
                         # 로컬 개발은 비워두면 Vite proxy 사용
