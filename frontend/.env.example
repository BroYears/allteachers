# ──────────────────────────────────────────────────────────────────────────────
# AllTeachers Frontend 환경 변수
# 사용법: 이 파일을 .env.local 로 복사 후 값 수정 (.env.local은 gitignore됨)
# ──────────────────────────────────────────────────────────────────────────────

# Spring Boot 백엔드 주소
# 개발: 비워두면 Vite proxy 사용 (/api/* → localhost:8080) → CORS 우회
# 프로덕션: 백엔드 서버 주소 직접 지정
VITE_API_URL=

# 프로덕션 예시
# VITE_API_URL=https://api.allteachers.co.kr
